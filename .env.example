# AI Auto child-service template environment baseline

# Shared domain baseline
APP_DOMAIN=auto-project-template.test
APP_BASE_URL=https://auto-project-template.test
APP_SCHEME=http
APP_HOST_IP=192.168.1.242

# Local development defaults
SERVICE_BACKEND_HOST=0.0.0.0
SERVICE_BACKEND_PORT=11010
SERVICE_FRONTEND_HOST=0.0.0.0
SERVICE_FRONTEND_PORT=11011
SERVICE_BACKEND_DATABASE_URL=sqlite+aiosqlite:///./service.db
SERVICE_WORKER_DATABASE_URL=sqlite+aiosqlite:///./service.db
SERVICE_BACKEND_SERVICE_PUBLIC_BASE_URL=http://192.168.1.242:11011
SERVICE_BACKEND_CORS_ALLOWED_ORIGINS=http://192.168.1.242:11011,http://192.168.1.242:4173
SERVICE_BACKEND_REQUIRE_HUB_AUTH=false
SERVICE_BACKEND_RUN_EMBEDDED_WORKER=false
SERVICE_BACKEND_WORKER_HEARTBEAT_PATH=.runtime/service-worker.json
SERVICE_WORKER_HEARTBEAT_PATH=.runtime/service-worker.json
VITE_API_BASE_URL=/api/v1
VITE_DEV_PROXY_TARGET=http://192.168.1.242:11010
VITE_REQUIRE_HUB_AUTH=false
VITE_DEV_HUB_USER_ID=local-dev-user
VITE_DEV_HUB_USER_NAME=Local Operator
VITE_DEV_HUB_ROLE=operator
VITE_HUB_LOGIN_URL=http://192.168.1.242:10011/login
VITE_HUB_API_BASE_URL=http://192.168.1.242:10010/api/v1

# Hub integration
SERVICE_BACKEND_HUB_API_URL=
SERVICE_BACKEND_HUB_API_V1_PREFIX=/api/v1
# Must match ai-auto Hub's HUB_BACKEND_INTERNAL_BOOTSTRAP_KEY when using internal bootstrap.
SERVICE_BACKEND_HUB_SERVICE_KEY=
SERVICE_BACKEND_HUB_SERVICE_ID=
SERVICE_BACKEND_HUB_SERVICE_TOKEN=
SERVICE_BACKEND_HUB_REQUEST_TIMEOUT_SECONDS=5
SERVICE_BACKEND_HUB_SERVICE_CREDENTIALS_PATH=.runtime/hub-service-credentials.json

# Shared environment / Docker Compose baseline
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
BACKEND_UPSTREAM=backend:11010
TLS_CERT_PATH=/etc/nginx/certs/tls.fullchain.crt
TLS_KEY_PATH=/etc/nginx/certs/tls.key
POSTGRES_DB=auto_project_template
POSTGRES_USER=auto_project_template
POSTGRES_PASSWORD=change-me
SHARED_SERVICE_BACKEND_DATABASE_URL=postgresql+psycopg://auto_project_template:change-me@postgres:5432/auto_project_template
SHARED_SERVICE_WORKER_DATABASE_URL=postgresql+psycopg://auto_project_template:change-me@postgres:5432/auto_project_template
SHARED_VITE_API_BASE_URL=/api/v1

# Internal TLS defaults
TLS_CA_NAME=AI Auto Service Template Internal Root CA
TLS_CA_VALID_DAYS=3650
TLS_CERT_VALID_DAYS=825
TLS_CERT_EXTRA_DNS_SANS=
TLS_CERT_IP_SANS=
